# ── Edoras Trading System — Required Environment Variables ──────
#
# Copy this file to ~/.config/edoras.env and fill in your values.
# Source it in your shell or systemd EnvironmentFile.
#
# cp .env.example ~/.config/edoras.env
# source ~/.config/edoras.env

# ── Coinbase API (CEX trading) ──────────────────────────────────
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

# ── Telegram Notifications ──────────────────────────────────────
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_GROUP_ID=your_telegram_group_id

# ── LLM APIs (for trading agent + sentiment) ────────────────────
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# ── DEX Trading (Bankr API) ────────────────────────────────────
BANKR_API_KEY=bk_...
DEX_WALLET_ADDRESS=0x...

# ── FRED (macroeconomic data, optional) ─────────────────────────
FRED_API_KEY=your_fred_api_key
